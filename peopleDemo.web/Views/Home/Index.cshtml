@using peopleData 
@Model PviewModel
@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

}
<div class="container">
    <main b-ud2x8zyu5z="" role="main" class="pb-3">
        <div class="row">
            <div class="col-md-12">
                <a href="/home/AddPeople" class="btn btn-success">Add People</a>
                <form method="post" action="/home/MultiDelete/">
                    <table class="table table-hover table-bordered">
                        <tbody>
                            <tr>
                                <th style="width:10%">
                                    <button class="btn btn-danger">Delete All</button>
                                </th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Age</th>
                            </tr>
                            
                            @foreach (Person person in Model.people)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="ids[]" value="@person.Id">
                                    </td>
                                    <td>@person.FirstName</td>
                                    <td>@person.LastName</td>
                                    <td>@person.Age</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </form>
            </div>
        </div>

    </main>
</div>